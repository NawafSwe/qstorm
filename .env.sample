# PubSub connection configurations.
PUBSUB__EMULATOR_HOST=localhost:8095
PUBSUB__PROJECT_ID=qstorm-project

# Kafka connection configurations (plaintext, no auth).
# Use with: docker compose up -d kafka
KAFKA__BOOTSTRAP_SERVERS=localhost:9092

# Kafka connection configurations (SASL auth).
# Use with: docker compose up -d kafka-sasl
# KAFKA__BOOTSTRAP_SERVERS=localhost:9093
# KAFKA__SECURITY_PROTOCOL=SASL_PLAINTEXT
# KAFKA__SASL_MECHANISM=PLAIN
# KAFKA__SASL_USERNAME=qstorm
# KAFKA__SASL_PASSWORD=qstorm-secret


# Rabitmq connection configurations
RABBITMQ__URL=amqp://guest:guest@localhost:5672


# Pulsar connection configurations
PULSAR__URL=pulsar://localhost:6650

# Pulsar basic auth
#PULSAR__BASIC_AUTH__USERNAME=guest
#PULSAR__BASIC_AUTH__PASSWORD=password

# Pulsar token auth
#PULSAR__AUTH_TOKEN=